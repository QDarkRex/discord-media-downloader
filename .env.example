# Copy to .env and fill in. NEVER commit the real .env.

# Discord bot token (Developer Portal -> your app -> Bot -> Reset Token)
BOT_TOKEN=

# Where SQLite db + temp downloads live (inside the container). Leave as-is.
DATA_PATH=./data

# OPTIONAL: TikTok burner cookies for more reliable monitoring.
# Put cookies.txt in ./data/ and point here. Leave blank to run without cookies.
# TIKTOK_COOKIES=/bot/data/cookies.txt
TIKTOK_COOKIES=

# OPTIONAL: route ALL TikTok traffic through a proxy, so TikTok sees the proxy's IP
# instead of the host server's (recommended on a shared server / at scale). Leave
# blank to use the server's own IP. Examples:
#   http://user:pass@host:port      socks5://host:port
TIKTOK_PROXY=

# --- Instagram (/ig command) ---------------------------------------------------
# Instagram login cookies (STRONGLY recommended — Instagram blocks most content for
# logged-out clients). Export a Netscape-format cookies.txt from a browser logged
# into a (preferably burner) Instagram account, drop it in ./data/, and point here.
# Leave blank to run anonymously (only the occasional public post will work).
# IG_COOKIES=/bot/data/ig_cookies.txt
IG_COOKIES=

# OPTIONAL: route Instagram traffic through a proxy (same idea as TIKTOK_PROXY).
IG_PROXY=
