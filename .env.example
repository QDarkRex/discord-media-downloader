# Copy to .env and fill in. NEVER commit the real .env.

# Discord bot token (Developer Portal -> your app -> Bot -> Reset Token)
BOT_TOKEN=

# Where SQLite db + temp downloads live (inside the container). Leave as-is.
DATA_PATH=./data

# OPTIONAL: TikTok burner cookies for more reliable monitoring.
# Put cookies.txt in ./data/ and point here. Leave blank to run without cookies.
# TIKTOK_COOKIES=/bot/data/cookies.txt
TIKTOK_COOKIES=

# OPTIONAL: route ALL TikTok traffic through a proxy, so TikTok sees the proxy's IP
# instead of the host server's (recommended on a shared server / at scale). Leave
# blank to use the server's own IP. Examples:
#   http://user:pass@host:port      socks5://host:port
TIKTOK_PROXY=

# EXPERIMENTAL: TikTok story monitoring.
# Export cookies.txt from a logged-in TikTok BURNER account and place it in ./data/.
# This is only used when `tiktok_story_enabled: true` in configs.yml.
# If blank, it falls back to TIKTOK_COOKIES.
# TIKTOK_STORY_COOKIES=/bot/data/tiktok_story_cookies.txt
TIKTOK_STORY_COOKIES=

# Optional separate proxy for the Playwright browser used by story discovery.
# Falls back to TIKTOK_PROXY when blank.
TIKTOK_STORY_PROXY=

# --- Instagram (/ig command + monitoring) --------------------------------------
# Instagram login cookies (required — Instagram walls posts behind login). Export a
# Netscape-format cookies.txt from a logged-in BURNER account, drop it in ./data/.
#
# You can list SEVERAL burner cookie files, comma-separated: watched accounts are
# sharded across them (each burner polls its own share), which halves per-account
# load. For that to actually reduce ban risk, give each burner its OWN proxy below
# (Instagram links accounts by IP).
# One burner:   IG_COOKIES=/bot/data/ig_cookies.txt
# Two burners:  IG_COOKIES=/bot/data/ig_cookies.txt,/bot/data/ig_cookies2.txt
IG_COOKIES=

# OPTIONAL proxies, paired to the burners above BY POSITION (1st proxy -> 1st burner).
# Strongly recommended for monitoring (the VPS is a datacenter IP Instagram distrusts).
# Examples:  http://user:pass@host:port   socks5://host:port
# One:   IG_PROXIES=http://user:pass@proxyA:port
# Two:   IG_PROXIES=http://user:pass@proxyA:port,http://user:pass@proxyB:port
IG_PROXIES=
# (Back-compat: a single IG_PROXY still works when you have one burner.)
IG_PROXY=
